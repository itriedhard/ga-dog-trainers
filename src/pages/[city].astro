---
import cityData from '../../cities.json';

export async function getStaticPaths() {
  return cityData.map((item) => ({
    params: { city: item.slug },
    props: { data: item },
  }));
}

const { data } = Astro.props;
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
<script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "The Best Dog Trainers in {data.city}, Georgia",
      "description": " Vetted rankings of the top local dog obedience trainers and board & train programs in the {data.city} area.",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Off Leash K9 Training"
        }
      ]
    }
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Best Dog Trainers in {data.city}, GA ({currentYear} Rankings)</title>
    <meta name="description" content={data.meta_desc}>
    <style>
        body { font-family: sans-serif; line-height: 1.6; max-width: 800px; margin: 0 auto; padding: 20px; color: #333; }
        h1 { color: #111; border-bottom: 2px solid #ddd; padding-bottom: 10px; }
        .trainer-card { border: 1px solid #eee; border-radius: 8px; padding: 20px; margin: 20px 0; background: #fbfbfb; }
        .rank-1 { border-left: 5px solid #ffcc00; background: #fffdf3; }
        .badge { background: #ffcc00; color: #000; padding: 3px 8px; font-size: 12px; font-weight: bold; border-radius: 4px; }
        .btn { display: inline-block; background: #0066cc; color: #fff; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold; margin-top: 10px; }
        .btn-gold { background: #e6b800; color: #000; }
    </style>
</head>
<body>

    <header>
        <h1>The Best Dog Trainers in {data.city}, Georgia</h1>
        <p>Vetted rankings of local dog obedience trainers, puppy schools, and board & train facilities near the {data.city} area.</p>
    </header>
<header>
        <h1>The Best Dog Trainers in {data.city}, Georgia</h1>
        <p>Vetted rankings of local dog obedience trainers, puppy schools, and board & train facilities near the {data.city} area.</p>
        
        <!-- PASTE THIS NEW LINE BELOW -->
        <p style="background: #f4f8ff; border-left: 4px solid #0066cc; padding: 15px; font-style: italic; margin-top: 20px;">
            <strong>Local City Insight:</strong> {data.local_tip}
        </p>
    </header>
    <main>
        <h2>Top Rated Service Providers</h2>
        
        {data.trainers.map((trainer) => (
            <div class={`trainer-card ${trainer.rank === 1 ? 'rank-1' : ''}`}>
                <h3>
                    #{trainer.rank}: {trainer.name} 
                    {trainer.rank === 1 && <span class="badge">TOP PICK</span>}
                </h3>
                <p><strong>Specialty:</strong> {trainer.specialty}</p>
                <p><strong>Credentials & Approach:</strong> {trainer.credentials_and_approach}</p>
                
                <a href={trainer.website} target="_blank" rel="noopener nofollow" class={`btn ${trainer.rank === 1 ? 'btn-gold' : ''}`}>
                    Visit {trainer.name} Website
                </a>
            </div>
        ))}
    </main>

    <footer>
        <hr />
        <p>Return to the local <a href="https://gatopdogtrainers.com/">Georgia Directory Hub</a>.</p>
    </footer>

</body>
</html>
